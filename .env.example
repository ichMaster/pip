# Copy this file to .env and fill in your values:  cp .env.example .env
# The .env file is git-ignored, so your key never gets committed.

# --- LLM voice (all optional) ----------------------------------------------

# Your Anthropic API key. Get one at https://console.anthropic.com/
# Leave blank to run on the offline templated voice (or use --rule).
ANTHROPIC_API_KEY=

# Which Anthropic model voices the creature.
PIP_MODEL=claude-haiku-4-5-20251001

# Max tokens per reply. Lines are short, so this stays small.
PIP_MAX_TOKENS=120
